}

/* Responsive adjustments */
@media (max-width: 768px) {
    .btn-nav {
        padding: 0.4rem 0.8rem;
        font-size: 14px;
    }
}

/* Focus state for accessibility */
.btn-nav:focus,
.btn-nav:focus-visible {
    outline: 2px solid var(--link-color);
    outline-offset: 2px;
}

    outline-color: #0078d4;
}

/* ========================================
   MEDIUM-INSPIRED COMPONENTS
   ======================================== */

/* Card Components */
.card {
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    overflow: hidden;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-sm);
}

.card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-medium);
}

.card-body {
    padding: var(--space-m);
}

/* Large Featured Card */
.card-featured {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
}

.card-featured:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.card-featured__image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
}

.card-featured__content {
    padding: var(--space-l);
}

.card-featured__title {
    font-size: var(--text-xl);
    line-height: 1.2;
    margin-bottom: var(--space-s);
    color: var(--text-primary);
    font-weight: 700;
}

.card-featured__excerpt {
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: var(--space-m);
}

.card-featured__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
}

/* Medium Grid Card */
.card-medium {
    display: flex;
    gap: var(--space-m);
    padding: var(--space-m);
    background: var(--card-bg);
    border-radius: 8px;
    border: 1px solid var(--border-light);
    transition: border-color var(--transition-fast);
}

.card-medium:hover {
    border-color: var(--border-medium);
}

.card-medium__content {
    flex: 1;
}

.card-medium__image {
    width: 120px;
    height: 120px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
}

/* Compact List Card */
.card-compact {
    padding: var(--space-m) 0;
    border-bottom: 1px solid var(--border-light);
}

.card-compact__title {
    font-size: var(--text-base);
    line-height: 1.4;
    margin-bottom: var(--space-xxs);
    font-weight: 600;
}

.card-compact__meta {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
}

/* Button System */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    font-size: var(--text-base);
    font-weight: 500;
    line-height: 1;
    border: none;
    border-radius: 24px;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    font-family: var(--font-sans);
}

.btn-primary {
    background: var(--accent-orange) !important;
    color: white !important;
    border: none !important;
}

.btn-primary:hover {
    background: #E55A10 !important;
    transform: scale(1.02);
    box-shadow: 0 4px 12px rgba(255, 103, 25, 0.3);
}

.btn-secondary {
    background: transparent !important;
    border: 1px solid var(--text-primary) !important;
    color: var(--text-primary) !important;
}

.btn-secondary:hover {
    background: var(--hover-bg) !important;
    transform: scale(1.02);
}

.btn-text {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    color: var(--text-primary) !important;
    text-decoration: none;
    border-bottom: 1px solid transparent !important;
}

.btn-text:hover {
    border-bottom-color: var(--text-primary) !important;
}

/* Blog Post Preview - Enhanced */
.blog-post-preview {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border-light);
    transition: all var(--transition-fast);
}

.blog-post-preview:hover {
    transform: translateX(4px);
}

.blog-post-preview h2 {
    font-size: var(--text-xl);
    line-height: 1.3;
    margin-bottom: var(--space-s);
    font-weight: 700;
}

.blog-post-preview h2 a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.blog-post-preview h2 a:hover {
    color: var(--accent-orange);
}

.blog-post-preview .meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-m);
}

.blog-post-preview .summary {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-m);
}

/* Hover Effects & Animations */
@keyframes lift {
    from {
        transform: translateY(0);
        box-shadow: var(--shadow-sm);
    }
    to {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
}

.hover-lift {
    animation: lift var(--transition-base) forwards;
}

/* Link Styles */
a {
    color: var(--link-color);
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--accent-orange);
}

/* Responsive Utilities */
@media (max-width: 768px) {
    :root {
        --text-3xl: 2.441rem;  /* 39px on mobile */
        --text-2xl: 1.953rem;  /* 31px on mobile */
    }
    
    .article-content {
        font-size: 1.125rem; /* 18px on mobile */
    }
    
    .card-medium {
        flex-direction: column;
    }
    
    .card-medium__image {
        width: 100%;
        height: 200px;
    }
}

/* ========================================
   BLOG HOMEPAGE LAYOUT
   ======================================== */

.blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xxl) var(--space-m);
}

.blog-header {
    text-align: center;
    margin-bottom: var(--space-xxl);
}

.blog-header h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
}

.blog-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
}

/* Featured Post */
.featured-post {
    margin-bottom: var(--space-xxl);
}

.featured-post__image-link {
    display: block;
    margin-bottom: var(--space-l);
    overflow: hidden;
    border-radius: 8px;
}

.featured-post__image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.featured-post__image-link:hover .featured-post__image {
    transform: scale(1.05);
}

.featured-post__content {
    max-width: 680px;
    margin: 0 auto;
}

.featured-post__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-m);
}

.featured-post__title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.featured-post__title a:hover {
    color: var(--accent-orange);
}

.featured-post__excerpt {
    font-size: var(--text-md);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-m);
}

.featured-post__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
}

.posts-divider {
    height: 1px;
    background: var(--border-light);
    margin: var(--space-xxl) 0;
}

/* Posts Grid */
.posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-xxl);
}

@media (max-width: 768px) {
    .posts-grid {
        grid-template-columns: 1fr;
        gap: var(--space-l);
    }
}

/* Post Card */
.post-card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    transition: all var(--transition-base);
    border: 1px solid transparent;
}

.post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-light);
}

.post-card__image-link {
    display: block;
    overflow: hidden;
}

.post-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.post-card__image-link:hover .post-card__image {
    transform: scale(1.05);
}

.post-card__content {
    padding: var(--space-m);
}

.post-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--space-s);
}

.post-card__title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.post-card__title a:hover {
    color: var(--accent-orange);
}

.post-card__excerpt {
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: var(--space-s);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.post-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xxs);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
}

.post-card__meta .divider {
    margin: 0 var(--space-xxs);
}

/* Author Card Component */
.author-card {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    padding: var(--space-l);
    background: var(--bg-secondary);
    border-radius: 8px;
    margin: var(--space-xl) 0;
}

.author-card__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
}

.author-card__info {
    flex: 1;
}

.author-card__name {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-xxs);
    color: var(--text-primary);
}

.author-card__bio {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
}

/* Social Share Buttons */
.social-share {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    margin: var(--space-xl) 0;
}

.social-share__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-secondary);
}

.social-share__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    text-decoration: none;
    transition: all var(--transition-fast);
    font-size: 1.125rem;
}

.social-share__button:hover {
    background: var(--accent-orange);
    color: white;
    transform: translateY(-2px);
}

.social-share__button--twitter:hover {
    background: #1DA1F2;
}

.social-share__button--linkedin:hover {
    background: #0A66C2;
}

.social-share__button--facebook:hover {
    background: #1877F2;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .featured-post__image {
        height: 250px;
    }
    
    .featured-post__title {
        font-size: var(--text-xl);
    }
    
    .featured-post__excerpt {
        font-size: var(--text-base);
    }
    
    .author-card {
        flex-direction: column;
        text-align: center;
    }
}

/* ========================================
   PHASE 3: PAGES
   ======================================== */

/* About Page */
.about-hero {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    padding: var(--space-xxxl) var(--space-m) var(--space-xxl);
    border-bottom: 1px solid var(--border-light);
}

.about-hero__container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-xxl);
}

.about-hero__avatar {
    flex-shrink: 0;
}

.about-hero__image {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--card-bg);
    box-shadow: var(--shadow-md);
}

.about-hero__placeholder {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-orange), var(--accent-green));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 700;
    color: white;
    border: 4px solid var(--card-bg);
    box-shadow: var(--shadow-md);
}

.about-hero__content {
    flex: 1;
}

.about-hero__title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-s);
    color: var(--text-primary);
}

.about-hero__subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin: 0;
}

.about-content {
    padding: var(--space-xxl) var(--space-m);
}

.about-content__container {
    max-width: 680px;
    margin: 0 auto;
}

.about-bio {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: 1.8;
    color: var(--text-primary);
    margin-bottom: var(--space-xxl);
}

.about-bio p {
    margin-bottom: var(--space-l);
}

.about-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-l);
    padding-top: var(--space-l);
    border-top: 1px solid var(--border-light);
}

.about-meta__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xxs);
}

.about-meta__label {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
}

.about-meta__value {
    font-size: var(--text-base);
    color: var(--text-primary);
}

/* Error Pages */
.error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 64px);
    padding: var(--space-l) var(--space-m);
}

.error-container {
    text-align: center;
}

.error-content {
    max-width: 500px;
}

.error-title {
    font-size: 8rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent-orange), var(--accent-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-l);
}

.error-heading {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-m);
}

.error-message {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xxl);
}

.error-actions {
    display: flex;
    gap: var(--space-m);
    justify-content: center;
    flex-wrap: wrap;
}

/* Article Page Enhancements */
.article-body {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-xxl) var(--space-m);
}

.article-header {
    max-width: 680px;
    margin: 0 auto var(--space-xxl);
}

.article-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-m);
    color: var(--text-primary);
}

.article-subtitle {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 var(--space-l);
}

.article-image {
    width: 100%;
    max-width: 800px;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    border-radius: 8px;
    margin: var(--space-xl) 0;
}

.article-meta-bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    padding: var(--space-m) 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
}

/* Table of Contents */
.toc {
    max-width: 680px;
    margin: var(--space-xl) auto;
    padding: var(--space-l);
    background: var(--bg-secondary);
    border-radius: 8px;
    border-left: 4px solid var(--accent-orange);
}

.toc h4 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-m);
    color: var(--text-primary);
}

.toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.toc li {
    margin-bottom: var(--space-xs);
}

.toc a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
}

.toc a:hover {
    color: var(--accent-orange);
}

.toc li ul {
    margin-left: var(--space-m);
    margin-top: var(--space-xs);
}

/* Related Posts Section */
.related-posts {
    max-width: 1200px;
    margin: var(--space-xxxl) auto 0;
    padding: var(--space-xxl) var(--space-m) 0;
    border-top: 1px solid var(--border-light);
}

.related-posts h3 {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-xl);
    color: var(--text-primary);
}

/* Skeleton Screens */
.skeleton {
    background: linear-gradient(
        90deg,
        var(--bg-secondary) 0%,
        var(--bg-tertiary) 50%,
        var(--bg-secondary) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 4px;
}

@keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}

.skeleton-text {
    height: 1em;
    margin-bottom: var(--space-xs);
}

.skeleton-line {
    height: 1rem;
    margin-bottom: var(--space-s);
}

.skeleton-image {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 8px;
}

.skeleton-card {
    padding: var(--space-m);
    background: var(--card-bg);
    border-radius: 8px;
    border: 1px solid var(--border-light);
}

/* Loading State */
.loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-s);
    color: var(--text-secondary);
    font-size: var(--text-sm);
}

.loading::after {
    content: '';
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-light);
    border-top-color: var(--accent-orange);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Responsive adjustments for Phase 3 */
@media (max-width: 768px) {
    .about-hero__container {
        flex-direction: column;
        text-align: center;
        padding: var(--space-xxl) var(--space-m) var(--space-xl);
    }
    
    .about-hero__image,
    .about-hero__placeholder {
        width: 120px;
        height: 120px;
        font-size: 2.5rem;
    }
    
    .error-title {
        font-size: 5rem;
    }
    
    .error-actions {
        flex-direction: column;
    }
    
    .error-actions .btn {
        width: 100%;
    }
    
    .article-body {
        padding: var(--space-xl) var(--space-m);
    }
    
    .toc {
        margin-left: 0;
        margin-right: 0;
    }
}

/* ========================================
   NEWSLETTER & FOOTER ENHANCEMENTS
   ======================================== */

.footer {
    background: var(--footer-bg);
    border-top: 1px solid var(--border-light);
    padding: var(--space-xxl) var(--space-m);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: background var(--transition-fast), color var(--transition-fast);
    flex-shrink: 0;
    margin-top: auto;
}

.footer-content {
    max-width: 1200px;
    margin: 0 auto;
}

.newsletter-section {
    margin-bottom: var(--space-xxl);
}

.newsletter-signup {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-xl);
    background: var(--bg-secondary);
    border-radius: 12px;
    border: 1px solid var(--border-light);
}

.newsletter-header {
    margin-bottom: var(--space-l);
}

.newsletter-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
}

.newsletter-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
}

.newsletter-form {
    margin-top: var(--space-m);
}

.newsletter-input-group {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-s);
}

.newsletter-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--border-light);
    border-radius: 6px;
    background: var(--card-bg);
    color: var(--text-primary);
    font-size: var(--text-base);
    transition: all var(--transition-fast);
}

.newsletter-input:focus {
    outline: none;
    border-color: var(--accent-orange);
    box-shadow: 0 0 0 3px rgba(255, 103, 25, 0.1);
}

.newsletter-btn {
    padding: 12px 24px;
    background: var(--accent-orange);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
}

.newsletter-btn:hover {
    background: #E55A10;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 103, 25, 0.3);
}

.newsletter-disclaimer {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin: 0;
}

.footer-bottom {
    padding-top: var(--space-l);
    border-top: 1px solid var(--border-light);
}

.footer-copyright {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin: 0;
}

/* Newsletter Alerts */
.newsletter-signup .alert {
    margin-top: var(--space-m);
    margin-bottom: var(--space-m);
    border-radius: 6px;
    font-size: var(--text-sm);
}

.newsletter-signup .alert-success {
    background: rgba(42, 200, 23, 0.1);
    border-color: var(--accent-green);
    color: var(--text-primary);
}

.newsletter-signup .alert-danger {
    background: rgba(220, 53, 69, 0.1);
    border-color: #dc3545;
    color: var(--text-primary);
}

/* Responsive newsletter */
@media (max-width: 768px) {
    .newsletter-input-group {
        flex-direction: column;
    }
    
    .newsletter-btn {
        width: 100%;
    }
    
    .newsletter-signup {
        padding: var(--space-l);
    }
}

/* ========================================
   DARK MODE ENHANCEMENTS & VERIFICATION
   ======================================== */

/* Dark mode shadows - more visible */
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.5);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.6);
    --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.7);
}

/* Dark mode links - ensure visibility */
    color: #5FB3FF;
}

