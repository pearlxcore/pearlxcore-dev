/* ?? Auth input placeholder � readable like helper text */
.auth-card .form-control::placeholder {
    color: var(--text-color);
    opacity: 0.6; /* key: readable but not dominant */
}

/* Dark mode override (slightly brighter) */
    color: var(--text-color);
