/* Keep keyboard accessibility */
:focus:not(:focus-visible) {
    outline: none;
}

/* ? Navigation Buttons Styling */
.btn-nav {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 1px solid transparent;
    color: var(--text-color);
}

.btn-nav:hover {
    text-decoration: none;
}

/* Login Button - Primary style */
.btn-login {
    background: var(--link-color);
    color: #ffffff !important;
    border-color: var(--link-color);
}

.btn-login:hover {
    background: #004080;
    border-color: #004080;
    box-shadow: 0 2px 8px rgba(0, 86, 179, 0.3);
    transform: translateY(-1px);
}

.btn-login:active {
    transform: translateY(0);
    box-shadow: 0 1px 4px rgba(0, 86, 179, 0.2);
}

/* Logout Button - Warning/Secondary style */
.btn-logout {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-color);
}

.btn-logout:hover {
    background: rgba(220, 53, 69, 0.1);
    border-color: #dc3545;
    color: #dc3545;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.2);
    transform: translateY(-1px);
}

.btn-logout:active {
    transform: translateY(0);
    box-shadow: 0 1px 4px rgba(220, 53, 69, 0.15);
}

/* Admin Button - Secondary style */
.btn-nav[href*="Admin"],
.btn-nav[asp-area="Admin"] {
    background: rgba(0, 122, 204, 0.1);
    border: 1px solid rgba(0, 122, 204, 0.3);
    color: var(--link-color);
}

.btn-nav[href*="Admin"]:hover,
.btn-nav[asp-area="Admin"]:hover {
    background: rgba(0, 122, 204, 0.2);
    border-color: var(--link-color);
    box-shadow: 0 2px 8px rgba(0, 122, 204, 0.15);
    transform: translateY(-1px);
}

.btn-nav[href*="Admin"]:active,
.btn-nav[asp-area="Admin"]:active {
    transform: translateY(0);
}

/* Dark theme adjustments */
    background: #0056b3;
}

