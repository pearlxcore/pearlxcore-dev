@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Settings";
}

<div class="admin-page">
    <div class="page-header mb-4">
        <h1 class="page-title mb-1">Settings</h1>
        <p class="text-muted mb-0">Manage your account and application settings</p>
    </div>

    <div class="row">
        <!-- Password Settings Card -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card admin-surface-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title admin-surface-card__title mb-2">
                        <i class="fas fa-lock"></i> Password
                    </h5>
                    <p class="card-text admin-surface-card__meta small mb-3">Change your admin password</p>
                    <p class="card-text admin-surface-card__text flex-grow-1">Secure your account by changing your password regularly.</p>
                    <a asp-area="Admin" asp-controller="Settings" asp-action="ChangePassword" class="btn btn-sm btn-primary admin-surface-card__button align-self-start">
                        <i class="fas fa-key"></i> Change Password
                    </a>
                </div>
            </div>
        </div>

        <!-- Account Information Card -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card admin-surface-card h-100">
                <div class="card-body">
                    <h5 class="card-title admin-surface-card__title mb-2">
                        <i class="fas fa-user"></i> Account
                    </h5>
                    <p class="card-text admin-surface-card__meta small mb-3">Your account information</p>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 small admin-surface-card__meta">Email:</dt>
                        <dd class="col-sm-8 admin-surface-card__text">@User.Identity?.Name</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- System Information Card -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card admin-surface-card h-100">
                <div class="card-body">
                    <h5 class="card-title admin-surface-card__title mb-2">
                        <i class="fas fa-info-circle"></i> System
                    </h5>
                    <p class="card-text admin-surface-card__meta small mb-3">Application information</p>
                    <dl class="row mb-0">
                        <dt class="col-sm-5 small admin-surface-card__meta">Application:</dt>
                                <dd class="col-sm-7 admin-surface-card__text">blog.pearlxcore.dev</dd>
                        <dt class="col-sm-5 small admin-surface-card__meta">Environment:</dt>
                        <dd class="col-sm-7 admin-surface-card__text">@(IHostingEnvironment.IsProduction() ? "Production" : IHostingEnvironment.IsStaging() ? "Staging" : "Development")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@inject IWebHostEnvironment IHostingEnvironment
