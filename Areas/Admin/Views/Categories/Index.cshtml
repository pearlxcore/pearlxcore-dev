@model IEnumerable<pearlxcore.dev.Models.Entities.Category>
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Categories";
}

<div class="admin-page">
    <div class="page-header mb-5">
        <h1 class="page-title">Categories</h1>
        <p class="page-subtitle">Organize your content with categories</p>
    </div>

    <div class="card admin-surface-card mb-5">
        <div class="card-body p-4">
            <h5 class="card-title admin-surface-card__title mb-3">Create Category</h5>
            <form method="post" asp-action="Create" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input name="name" placeholder="Category name" class="form-control" required />
                <button type="submit" class="btn btn-primary admin-surface-card__button"><i class="fas fa-plus"></i>Add</button>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info admin-surface-alert" role="alert">
            No categories yet. Create your first category above!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var c in Model.OrderBy(x => x.Name))
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card admin-surface-card h-100">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title admin-surface-card__title">@c.Name</h5>
                                <p class="card-text admin-surface-card__meta small">@c.Slug</p>
                            </div>
                            <form method="post" asp-action="Delete" asp-route-id="@c.Id" style="display:inline;" onsubmit="return confirm('Delete this category?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-back-cancel admin-surface-card__delete" title="Delete category">
                                    <i class="fas fa-trash-alt"></i>Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
