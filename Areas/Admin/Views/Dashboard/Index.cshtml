@model pearlxcore.dev.ViewModels.Admin.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-page">
    <div class="page-header mb-5">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Content management overview and quick actions</p>
    </div>

    <div class="row mb-4">
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Total Posts</p>
                    <h3 class="dashboard-stat__value">@Model.TotalPosts</h3>
                </div>
                <i class="fas fa-file-alt dashboard-stat__icon"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat dashboard-stat--success">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Published</p>
                    <h3 class="dashboard-stat__value">@Model.PublishedPosts</h3>
                </div>
                <i class="fas fa-check-circle dashboard-stat__icon"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat dashboard-stat--muted">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Drafts</p>
                    <h3 class="dashboard-stat__value">@Model.DraftPosts</h3>
                </div>
                <i class="fas fa-edit dashboard-stat__icon"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat dashboard-stat--warning">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Scheduled</p>
                    <h3 class="dashboard-stat__value">@Model.ScheduledPosts</h3>
                </div>
                <i class="fas fa-clock dashboard-stat__icon"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat dashboard-stat--info">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Categories</p>
                    <h3 class="dashboard-stat__value">@Model.TotalCategories</h3>
                </div>
                <i class="fas fa-list dashboard-stat__icon"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="dashboard-stat dashboard-stat--purple">
                <div class="dashboard-stat__content">
                    <p class="dashboard-stat__label">Tags</p>
                    <h3 class="dashboard-stat__value">@Model.TotalTags</h3>
                </div>
                <i class="fas fa-tags dashboard-stat__icon"></i>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card admin-summary-card h-100">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <p class="admin-summary-card__label mb-1">IMAGES</p>
                            <h3 class="admin-summary-card__value admin-summary-card__value--danger">@Model.TotalImagesCount</h3>
                            <p class="admin-summary-card__meta mb-0">@Model.FormattedImageSize</p>
                        </div>
                        <i class="fas fa-image admin-summary-card__icon admin-summary-card__icon--danger"></i>
                    </div>
                </div>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.LastPublishedTitle))
        {
            <div class="col-sm-6 col-lg-3 mb-4">
                <div class="card admin-summary-card h-100">
                    <div class="card-body">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div style="flex: 1;">
                                <p class="admin-summary-card__label mb-1">LAST PUBLISHED</p>
                                <h5 class="admin-summary-card__title mb-1">@Model.LastPublishedTitle</h5>
                                <p class="admin-summary-card__meta mb-0">@Model.LastPublishedDate?.ToString("MMM dd, yyyy 'at' h:mm tt")</p>
                            </div>
                            <i class="fas fa-star admin-summary-card__icon"></i>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mb-5">
        <div class="col-lg-6 mb-4">
            <div class="content-section admin-dashboard-feed">
                <div class="content-section__header admin-dashboard-feed__header">
                    <h3 class="content-section__title admin-dashboard-feed__title">
                        <i class="fas fa-check-circle"></i> Recent Posts
                    </h3>
                </div>
                @if (Model.RecentPosts.Any())
                {
                    <ul class="content-list admin-dashboard-feed__list">
                        @foreach (var post in Model.RecentPosts)
                        {
                            <li class="content-list__item admin-dashboard-feed__item">
                                <div class="content-list__left">
                                    <h4 class="content-list__title">
                                        <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@post.Id">@post.Title</a>
                                    </h4>
                                    <div class="content-list__meta">
                                        <div class="content-list__meta-item">
                                            <span class="content-list__meta-label">Author</span>
                                            <span>@(Model.AdminProfile?.Name ?? "Author")</span>
                                        </div>
                                        <div class="content-list__meta-item">
                                            <span class="content-list__meta-label">Published</span>
                                            <span>@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="content-list__empty admin-dashboard-feed__empty">No published posts yet.</div>
                }
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="content-section admin-dashboard-feed">
                <div class="content-section__header admin-dashboard-feed__header">
                    <h3 class="content-section__title admin-dashboard-feed__title">
                        <i class="fas fa-pencil-alt"></i> Recent Drafts
                    </h3>
                </div>
                @if (Model.RecentDrafts.Any())
                {
                    <ul class="content-list admin-dashboard-feed__list">
                        @foreach (var post in Model.RecentDrafts)
                        {
                            <li class="content-list__item admin-dashboard-feed__item">
                                <div class="content-list__left">
                                    <h4 class="content-list__title">
                                        <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@post.Id">@post.Title</a>
                                    </h4>
                                    <div class="content-list__meta">
                                        <div class="content-list__meta-item">
                                            <span class="content-list__meta-label">Author</span>
                                            <span>@(Model.AdminProfile?.Name ?? "Author")</span>
                                        </div>
                                        <div class="content-list__meta-item">
                                            <span class="content-list__meta-label">Created</span>
                                            <span>@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="content-list__empty admin-dashboard-feed__empty">No drafts.</div>
                }
            </div>
        </div>
    </div>

    @if (Model.ScheduledPostsList.Any())
    {
        <div class="row mb-5">
            <div class="col-12">
                <div class="card admin-scheduled-card">
                    <div class="card-header admin-scheduled-card__header">
                        <h5 class="mb-0 admin-scheduled-card__title"><i class="fas fa-hourglass-end"></i>Scheduled Posts</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="border-top: none;">Title</th>
                                        <th style="border-top: none;">Author</th>
                                        <th style="border-top: none;">Scheduled For</th>
                                        <th style="border-top: none;">Time Until Publish</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var post in Model.ScheduledPostsList)
                                    {
                                        var timeUntil = post.ScheduledPublishAt!.Value - DateTime.UtcNow;
                                        <tr>
                                            <td>
                                                <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@post.Id" style="text-decoration: none; color: #212529; font-weight: 500;">
                                                    @post.Title
                                                </a>
                                            </td>
                                            <td class="text-muted">@(Model.AdminProfile?.Name ?? "Author")</td>
                                            <td class="text-muted" style="font-size: 0.875rem;">
                                                @post.ScheduledPublishAt?.ToLocalTime().ToString("MMM dd, yyyy 'at' h:mm tt")
                                            </td>
                                            <td class="text-muted" style="font-size: 0.875rem;">
                                                @if (timeUntil.TotalHours < 1)
                                                {
                                                    <span class="badge bg-warning text-dark">@((int)timeUntil.TotalMinutes) min</span>
                                                }
                                                else if (timeUntil.TotalDays < 1)
                                                {
                                                    <span class="badge bg-info text-dark">@((int)timeUntil.TotalHours) hrs</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@((int)timeUntil.TotalDays) days</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="quick-actions">
        <div class="quick-actions__header">
            <h3 class="quick-actions__title">
                <i class="fas fa-lightning-bolt"></i> Quick Actions
            </h3>
        </div>
        <div class="quick-actions__grid">
            <a asp-area="Admin" asp-controller="Posts" asp-action="Create" class="quick-action-btn">
                <i class="fas fa-plus"></i>
                <span class="quick-action-btn__label">Create New Post</span>
            </a>
            <a asp-area="Admin" asp-controller="Posts" asp-action="Index" class="quick-action-btn">
                <i class="fas fa-folder"></i>
                <span class="quick-action-btn__label">Manage Posts</span>
            </a>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="quick-action-btn">
                <i class="fas fa-sitemap"></i>
                <span class="quick-action-btn__label">Manage Categories</span>
            </a>
            <a asp-area="Admin" asp-controller="Tags" asp-action="Index" class="quick-action-btn">
                <i class="fas fa-tag"></i>
                <span class="quick-action-btn__label">Manage Tags</span>
            </a>
        </div>
    </div>
</div>
