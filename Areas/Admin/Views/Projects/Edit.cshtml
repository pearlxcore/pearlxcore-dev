@model pearlxcore.dev.ViewModels.Admin.Projects.ProjectFormViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Edit Project";
}

<div class="admin-page">
    <div class="page-header page-header--centered mb-4">
        <div>
            <h1 class="page-title mb-1">Edit Project</h1>
            <p class="page-subtitle mb-0">Update this project entry</p>
        </div>
    </div>

    <div class="card admin-surface-card">
        <div class="card-body">
            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Title" class="form-label admin-form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Project title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SortOrder" class="form-label admin-form-label">Sort Order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ProjectType" class="form-label admin-form-label">Project Type</label>
                        <select asp-for="ProjectType" asp-items="ViewBag.ProjectTypeOptions" class="form-select"></select>
                        <span asp-validation-for="ProjectType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Platform" class="form-label admin-form-label">Platform</label>
                        <select asp-for="Platform" asp-items="ViewBag.ProjectPlatformOptions" class="form-select"></select>
                        <span asp-validation-for="Platform" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label admin-form-label">Status</label>
                        <select asp-for="Status" asp-items="ViewBag.ProjectStatusOptions" class="form-select"></select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label admin-form-label">Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <textarea asp-for="Description"
                                  class="form-control project-markdown-editor"
                                  data-markdown-editor="true"
                                  data-markdown-upload-endpoint="/Admin/Posts/UploadImage"
                                  data-markdown-preview-endpoint="/Admin/Posts/PreviewMarkdown"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="GitHubUrl" class="form-label admin-form-label">GitHub Repo URL</label>
                        <input asp-for="GitHubUrl" class="form-control" />
                        <span asp-validation-for="GitHubUrl" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ScreenshotFile" class="form-label admin-form-label">Screenshot Image</label>
                        @if (!string.IsNullOrWhiteSpace(Model.ScreenshotUrl))
                        {
                            <div class="project-form__preview mb-3">
                                <img src="@Model.ScreenshotUrl" alt="@Model.Title screenshot" class="project-form__preview-image" />
                            </div>
                        }
                        <div class="file-upload" data-file-upload>
                            <input asp-for="ScreenshotFile" type="file" class="file-upload__input" accept=".jpg,.jpeg,.png,.gif,.webp" />
                            <button type="button" class="file-upload__button">Choose File</button>
                            <input type="text" class="file-upload__text" value="No file chosen" readonly />
                        </div>
                        <span asp-validation-for="ScreenshotFile" class="text-danger"></span>
                    </div>
                </div>

                <div class="admin-form-actions mt-4">
                    <a asp-action="Index" class="btn btn-back-cancel">Back</a>
                    <button type="submit" class="btn btn-primary admin-surface-card__button">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/editor.js" asp-append-version="true"></script>
}
