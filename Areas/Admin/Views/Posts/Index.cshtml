@model pearlxcore.dev.Models.PaginatedList<pearlxcore.dev.Models.Entities.Post>
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Posts";
}

<div class="admin-page">
    <div class="page-header mb-5">
        <div class="admin-header-top">
            <div>
                <h1 class="page-title">Posts</h1>
                <p class="page-subtitle">Create, edit, and manage your blog articles</p>
            </div>
            <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i><span>New Post</span></a>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-state__icon">📝</div>
            <h3 class="empty-state__title">No posts yet</h3>
            <p class="empty-state__text">Create your first blog post and share your ideas with the world.</p>
            <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i><span>Create Post</span></a>
        </div>
    }
    else
    {
        <div class="posts-list">
            @foreach (var post in Model.Items)
            {
                <div class="post-list-item">
                    <div class="post-list-item__row">
                        <div class="post-list-item__title">
                            <a asp-action="Edit" asp-route-id="@post.Id">@post.Title</a>
                            <span class="post-list-item__slug">/@post.Slug</span>
                        </div>
                        <div class="post-list-item__status">
                            @if (post.IsPublished)
                            {
                                <span class="status-badge status-published"><i class="fas fa-check-circle"></i> Published</span>
                            }
                            else if (post.ScheduledPublishAt != null && post.ScheduledPublishAt > DateTime.UtcNow)
                            {
                                <span class="status-badge status-scheduled"><i class="fas fa-clock"></i> Scheduled</span>
                            }
                            else
                            {
                                <span class="status-badge status-draft"><i class="fas fa-edit"></i> Draft</span>
                            }
                        </div>
                    </div>
                    <div class="post-list-item__meta">
                        <span class="meta-item">By @post.Author?.Email</span>
                        <span class="meta-item">Created @post.CreatedAt.ToString("MMM dd, yyyy")</span>
                        <span class="meta-item">Updated @(post.UpdatedAt?.ToString("MMM dd, yyyy") ?? "-")</span>
                        @if (post.ScheduledPublishAt != null && post.ScheduledPublishAt > DateTime.UtcNow)
                        {
                            <span class="meta-item">Scheduled @post.ScheduledPublishAt?.ToLocalTime().ToString("MMM dd, h:mm tt")</span>
                        }
                    </div>
                    <div class="post-list-item__actions">
                        <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-primary btn-sm"><i class="fas fa-edit"></i><span>Edit</span></a>
                        <form method="post" asp-action="Delete" asp-route-id="@post.Id" class="post-list-item__delete-form" onsubmit="return confirm('Delete this post permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i><span>Delete</span></button>
                        </form>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Posts pagination" class="pagination-nav">
                <ul class="pagination">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" aria-label="Previous">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" aria-label="Next">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="pagination-info">
                <small>Showing @((Model.PageIndex - 1) * Model.PageSize + 1) to @Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount) of @Model.TotalCount posts</small>
            </div>
        }
    }
</div>
