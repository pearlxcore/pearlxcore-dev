@model pearlxcore.dev.Models.Entities.AdminProfile
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "About Me";
}

<div class="admin-page">
    <div class="page-header page-header--centered mb-4">
        <div>
            <h1 class="page-title mb-1">About Me</h1>
            <p class="text-muted mb-0">Profile details for your admin identity</p>
        </div>
    </div>

    <div class="card admin-surface-card">
        <div class="card-body d-flex flex-wrap gap-4 align-items-start">
            <div class="avatar-wrapper" style="width:140px;">
                @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Admin avatar" class="img-fluid rounded" />
                }
                else
                {
                    <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="width:140px;height:140px;">
                        <span class="text-muted">No Avatar</span>
                    </div>
                }
            </div>
            <div class="flex-grow-1">
                <h3 class="mb-1">@Model.Name</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Title))
                {
                    <p class="text-muted mb-2">@Model.Title</p>
                }
                <div class="mt-3">
                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <p class="mb-0" style="white-space:pre-line">@Model.Bio</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No bio yet. Click edit to add one.</p>
                    }
                </div>
                <p class="text-muted small mt-3">Last updated: @Model.UpdatedAt.ToLocalTime().ToString("g")</p>
            </div>
        </div>
        <div class="card-footer admin-card-footer">
            <a asp-action="Edit" class="btn btn-primary">Edit Profile</a>
        </div>
    </div>
</div>
