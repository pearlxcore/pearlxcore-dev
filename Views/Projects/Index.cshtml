@model IEnumerable<pearlxcore.dev.Models.Entities.Project>
@using pearlxcore.dev.Infrastructure
@{
    ViewData["Title"] = "Projects";
    var projects = Model.OrderBy(p => p.SortOrder).ThenBy(p => p.Title).ToList();
}

<section class="projects-hero">
    <div class="projects-hero__inner">
        <p class="projects-hero__eyebrow">Open Source Archive</p>
        <h1 class="projects-hero__title">Projects</h1>
        <p class="projects-hero__lead">
            Archived desktop apps, community tools, mobile utilities, and automation work gathered in one place.
        </p>
    </div>
</section>

<section class="projects-grid">
    @if (!projects.Any())
    {
        <div class="empty-state">
            <h3>No projects yet</h3>
            <p>Projects will appear here once they&apos;re added from the admin panel.</p>
        </div>
    }
    else
    {
        foreach (var project in projects)
        {
            var detailsUrl = Url.Action("Details", "Projects", new { id = project.Id }) ?? "#";

            <article class="project-card">
                <div class="project-card__body">
                    <div class="project-card__header-row">
                        <div class="project-card__header-text">
                            <h2 class="project-card__title">
                                <a href="@detailsUrl">@project.Title</a>
                            </h2>

                            <div class="project-card__taxonomy-inline">
                                <div class="post-taxonomy__chips">
                                    <span class="project-card__badge project-card__badge--platform">@project.Platform</span>
                                    <span class="project-card__badge project-card__badge--type">@project.ProjectType</span>
                                    <span class="project-card__badge @GetStatusBadgeClass(project.Status)">@project.Status</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <a href="@detailsUrl" class="project-card__media-link">
                        @if (!string.IsNullOrWhiteSpace(project.ScreenshotUrl))
                        {
                            <img src="@project.ScreenshotUrl" alt="@project.Title" class="project-card__image" />
                        }
                        else
                        {
                            <div class="project-card__placeholder">
                                <span>@project.Title</span>
                            </div>
                        }
                    </a>
                </div>
            </article>
        }
    }
</section>

@functions {
    private static string GetStatusBadgeClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "active" => "project-card__badge--active",
            "experimental" => "project-card__badge--experimental",
            "inactive" => "project-card__badge--inactive",
            _ => "project-card__badge--archived",
        };
    }
}
