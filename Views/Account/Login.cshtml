@model pearlxcore.dev.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="home-content">
    <div class="card auth-card" aria-labelledby="signin-title">
        <div class="card-body">
            <header class="auth-card__header text-center mb-4">
                <h1 id="signin-title" class="auth-card__title mb-2">Welcome Back</h1>
                <p class="auth-card__meta small mb-0">Sign in to access the admin panel</p>
            </header>

            <form asp-action="Login" method="post" novalidate role="form">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ReturnUrl" />

                @if (ViewData.ModelState["Error"] != null)
                {
                    <div class="alert alert-danger mb-3" role="alert">
                        <small>Invalid email or password. Please try again.</small>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label admin-form-label">Email Address</label>
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="you@example.com"
                           autocomplete="email"
                           required />
                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label admin-form-label">Password</label>
                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           placeholder="Enter password"
                           autocomplete="current-password"
                           required />
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" id="RememberMe" />
                    <label asp-for="RememberMe" class="form-check-label">Keep me signed in</label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Sign In</button>
                </div>
            </form>
        </div>
    </div>
</div>
