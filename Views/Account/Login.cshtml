@model pearlxcore.dev.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="home-content">
    <div class="auth-card card p-5 shadow-sm" aria-labelledby="signin-title" style="max-width: 420px; margin: 3rem auto;">
        <header class="text-center mb-4">
            <h1 id="signin-title" class="h3 mb-2" style="font-weight: 600;">Welcome Back</h1>
            <p class="text-muted small mb-0">Sign in to access the admin panel</p>
        </header>

        <form asp-action="Login" method="post" class="mt-4" novalidate role="form">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="ReturnUrl" />

            @if (ViewData.ModelState["Error"] != null)
            {
                <div class="alert alert-danger mb-3" role="alert">
                    <small>Invalid email or password. Please try again.</small>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="you@example.com"
                       autocomplete="email"
                       required />
                <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       required />
                <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" id="RememberMe" />
                <label asp-for="RememberMe" class="form-check-label">Keep me signed in</label>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg" style="font-weight: 500;">Sign In</button>
            </div>
        </form>
    </div>
</div>