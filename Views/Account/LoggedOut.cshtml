@{
    ViewData["Title"] = "Logged Out";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-success">
                <div class="card-body text-center">
                    <h1 class="card-title text-success mb-4">✓ Logged Out</h1>
                    <p class="card-text mb-4">You have been successfully logged out.</p>
                    <p class="card-text text-muted mb-4">You can close this page or login again to continue.</p>
                    
                    <div class="button-group">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Home</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login Again</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
