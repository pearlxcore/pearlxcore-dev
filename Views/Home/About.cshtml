@model pearlxcore.dev.Models.Entities.AdminProfile
@{
    ViewData["Title"] = "About";
}

<!-- About Hero Section -->
<section class="about-hero">
    <div class="about-hero__container">
        <div class="about-hero__avatar">
            @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl" alt="@Model.Name" class="about-hero__image" />
            }
            else
            {
                <div class="about-hero__placeholder">
                    @if (!string.IsNullOrEmpty(Model.Name))
                    {
                        <span>@Model.Name.Substring(0, 1).ToUpper()</span>
                    }
                </div>
            }
        </div>
        <div class="about-hero__content">
            <h1 class="about-hero__title">@Model.Name</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Title))
            {
                <p class="about-hero__subtitle">@Model.Title</p>
            }
        </div>
    </div>
</section>

<!-- About Content Section -->
<section class="about-content">
    <div class="about-content__container">
        <div class="about-profile-panel">
            <div class="about-profile-panel__bio">
                <h2 class="about-profile-panel__heading">About Me</h2>
                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <div class="about-bio">
                        @Html.Raw(Model.Bio.Replace("\n", "<br />"))
                    </div>
                }
                else
                {
                    <p class="about-profile-panel__empty">This author hasn't written a bio yet.</p>
                }
            </div>

            <div class="about-profile-panel__contact">
                <h2 class="about-profile-panel__heading">Get In Touch</h2>
                <div class="about-contact__grid">
                    <a href="mailto:moehammadizzat@gmail.com" class="about-contact__item">
                        <span class="about-contact__label">📧 Email</span>
                        <span class="about-contact__value">moehammadizzat@gmail.com</span>
                    </a>

                    <a href="tel:0176612934" class="about-contact__item">
                        <span class="about-contact__label">📱 Phone</span>
                        <span class="about-contact__value">0176612934</span>
                    </a>

                    <a href="https://github.com/pearlxcore" target="_blank" rel="noopener noreferrer" class="about-contact__item">
                        <span class="about-contact__label">💻 GitHub</span>
                        <span class="about-contact__value">pearlxcore</span>
                    </a>

                    @if (!string.IsNullOrEmpty(Model.CvUrl))
                    {
                        <a href="@Model.CvUrl" target="_blank" rel="noopener noreferrer" class="about-contact__item">
                            <span class="about-contact__label">📄 Resume/CV</span>
                            <span class="about-contact__value">Download CV</span>
                        </a>
                    }
                </div>
            </div>

            <div class="about-profile-panel__footer">
                <span class="about-meta__label">Profile updated</span>
                <span class="about-meta__value">@Model.UpdatedAt.ToLocalTime().ToString("MMMM dd, yyyy")</span>
            </div>
        </div>
    </div>
</section>
