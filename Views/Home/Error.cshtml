@{
    ViewData["Title"] = "Oops! Something went wrong";
}

<section class="error-page">
    <div class="error-container">
        <div class="error-content text-center">
            <h1 class="error-title">500</h1>
            <h2 class="error-heading">Something went wrong</h2>
            <p class="error-message">We encountered an unexpected error. Please try again later or contact support if the problem persists.</p>
            <a href="/" class="btn btn-back-cancel">Back to Home</a>
        </div>
    </div>
</section>
