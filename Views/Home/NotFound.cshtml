@{
    ViewData["Title"] = "Page Not Found";
}

<section class="error-page">
    <div class="error-container">
        <div class="error-content">
            <h1 class="error-title">404</h1>
            <h2 class="error-heading">Page not found</h2>
            <p class="error-message">The page you're looking for doesn't exist. It might have been moved or deleted.</p>
            <div class="error-actions">
                <a asp-controller="Home" asp-action="Index" class="btn btn-back-cancel">Back to Home</a>
                <a asp-controller="Blog" asp-action="Index" class="btn btn-secondary">View Blog</a>
            </div>
        </div>
    </div>
</section>
