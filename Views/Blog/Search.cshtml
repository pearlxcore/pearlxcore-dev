@model pearlxcore.dev.Models.PaginatedList<pearlxcore.dev.Models.Entities.Post>
@{
    ViewData["Title"] = ViewData["Title"]?.ToString() ?? "Search Results";
    var searchQuery = ViewData["SearchQuery"] as string;
    var adminProfile = ViewData["AdminProfile"] as pearlxcore.dev.Models.Entities.AdminProfile;
}

<div class="blog-list">
    <div class="page-header mb-4" style="text-align: center;">
        <h1 class="page-title">@ViewData["Title"]</h1>
        @if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            <p class="page-subtitle">Found @Model.TotalCount result@(Model.TotalCount != 1 ? "s" : "")</p>
        }
    </div>

    @* Search Box *@
    <div class="mb-5" style="max-width: 600px; margin: 0 auto;">
        <form method="get" action="/blog/search" class="d-flex gap-2">
            <input type="search" 
                   name="q" 
                   class="form-control form-control-lg" 
                   placeholder="Search posts..." 
                   value="@searchQuery"
                   autofocus>
            <button type="submit" class="btn btn-primary btn-lg px-4">
                🔍 Search
            </button>
        </form>
    </div>

    @if (Model.TotalCount == 0)
    {
        <div class="alert alert-info text-center py-5">
            @if (string.IsNullOrWhiteSpace(searchQuery))
            {
                <p class="mb-0">Enter a search term to find posts.</p>
            }
            else
            {
                <p class="mb-0">No posts found matching <strong>"@searchQuery"</strong>.</p>
                <p class="mt-2 mb-0"><a asp-controller="Blog" asp-action="Index">View all posts</a></p>
            }
        </div>
    }
    else
    {
        @foreach (var post in Model.Items)
        {
            var wordCount = post.Content?.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length ?? 0;
            var readingTime = Math.Ceiling(wordCount / 200.0);
            <div class="blog-post-preview">
                <h2>
                    <a asp-controller="Blog"
                       asp-action="Post"
                       asp-route-slug="@post.Slug"
                       class="text-decoration-none">
                        @post.Title
                    </a>
                </h2>
                @if (!string.IsNullOrEmpty(post.ImageUrl))
                {
                    <img src="@post.ImageUrl" alt="@post.Title" style="max-width: 100%; height: auto; border-radius: 8px; margin: 1rem 0; max-height: 300px; object-fit: cover;" />
                }
                <div class="meta">
                    <span class="author">By @(adminProfile?.Name ?? post.Author.UserName)</span>
                    <span class="divider">•</span>
                    <span class="date">@post.PublishedAt?.ToString("MMMM dd, yyyy")</span>
                    <span class="divider">•</span>
                    <span class="reading-time">@readingTime min read</span>
                </div>
                @if (!string.IsNullOrEmpty(post.Summary))
                {
                    <p class="summary">@post.Summary</p>
                }
                @if (post.PostCategories.Any())
                {
                    <div class="mb-2">
                        @foreach (var pc in post.PostCategories)
                        {
                            <a asp-controller="Blog" 
                               asp-action="Category" 
                               asp-route-slug="@pc.Category.Slug"
                               class="badge bg-secondary text-decoration-none me-1">
                                @pc.Category.Name
                            </a>
                        }
                    </div>
                }
                <a asp-controller="Blog"
                   asp-action="Post"
                   asp-route-slug="@post.Slug"
                   class="btn btn-sm btn-outline-primary">Read More →</a>
            </div>
        }

        @* Pagination Controls *@
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Search pagination" class="mt-5">
                <ul class="pagination justify-content-center">
                    @* Previous Button *@
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" 
                           asp-controller="Blog" 
                           asp-action="Search" 
                           asp-route-q="@searchQuery"
                           asp-route-page="@(Model.PageIndex - 1)"
                           aria-label="Previous">
                            <span aria-hidden="true">&laquo; Previous</span>
                        </a>
                    </li>

                    @* Page Numbers *@
                    @{
                        var startPage = Math.Max(1, Model.PageIndex - 2);
                        var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                    }

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" 
                               asp-controller="Blog" 
                               asp-action="Search"
                               asp-route-q="@searchQuery"
                               asp-route-page="1">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (var i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" 
                               asp-controller="Blog" 
                               asp-action="Search"
                               asp-route-q="@searchQuery"
                               asp-route-page="@i">@i</a>
                        </li>
                    }

                    @if (endPage < Model.TotalPages)
                    {
                        @if (endPage < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" 
                               asp-controller="Blog" 
                               asp-action="Search"
                               asp-route-q="@searchQuery"
                               asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                        </li>
                    }

                    @* Next Button *@
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" 
                           asp-controller="Blog" 
                           asp-action="Search"
                           asp-route-q="@searchQuery"
                           asp-route-page="@(Model.PageIndex + 1)"
                           aria-label="Next">
                            <span aria-hidden="true">Next &raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="text-center text-muted mt-3">
                <small>Showing @((Model.PageIndex - 1) * Model.PageSize + 1) to @Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount) of @Model.TotalCount posts</small>
            </div>
        }
    }
</div>
