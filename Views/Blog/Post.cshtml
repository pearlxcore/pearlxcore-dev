@model pearlxcore.dev.Models.Entities.Post
@using pearlxcore.dev.Models.Entities

@{
    ViewData["MetaDescription"] = Model.Summary ?? Model.Title;
    ViewData["Title"] = Model.Title;
    var wordCount = Model.Content?.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length ?? 0;
    var readingTime = Math.Ceiling(wordCount / 200.0);
    var adminProfile = ViewData["AdminProfile"] as pearlxcore.dev.Models.Entities.AdminProfile;
    var relatedPosts = ViewData["RelatedPosts"] as IEnumerable<Post> ?? Enumerable.Empty<Post>();
}

<article class="article-body">
    <div class="article-back">
        <a asp-controller="Blog" asp-action="Index" class="article-back__link btn-back-cancel">← Back to Articles</a>
    </div>

    <h1 class="article-title">@Model.Title</h1>

    @if (!string.IsNullOrEmpty(Model.Summary))
    {
        <p class="article-subtitle">@Model.Summary</p>
    }

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Title" class="article-hero-image" />
    }

    <div class="article-author">
        @if (adminProfile?.AvatarUrl != null)
        {
            <img src="@adminProfile.AvatarUrl" alt="@adminProfile.Name" />
        }
        else
        {
            <div class="article-author__avatar-fallback">
                @(adminProfile?.Name?.Substring(0, 1).ToUpper() ?? "A")
            </div>
        }
        <div class="author-info">
            <h4><a asp-controller="Home" asp-action="About">@(adminProfile?.Name ?? Model.Author.UserName)</a></h4>
            <p>Published @Model.PublishedAt?.ToString("MMMM dd, yyyy") • @readingTime min read</p>
        </div>
    </div>

    <hr class="article-divider" />
    @if (readingTime > 5)
    {
        <div class="toc">
            <h4>Table of Contents</h4>
            <ul id="toc-list">
                <!-- TOC will be generated by JS -->
            </ul>
        </div>
    }

    <div class="article-content">
        @Html.Raw(Model.RenderedContent ?? Model.Content)
    </div>

    @if (Model.PostCategories.Any() || Model.PostTags.Any())
    {
        <div class="article-taxonomy-card">
            @if (Model.PostCategories.Any())
            {
                <div class="post-taxonomy">
                    <strong>Categories</strong>
                    <div class="post-taxonomy__chips">
                        @foreach (var c in Model.PostCategories.Select(pc => pc.Category))
                        {
                            <a asp-controller="Blog"
                               asp-action="Category"
                               asp-route-slug="@c.Slug"
                               class="badge bg-secondary">
                                @c.Name
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.PostTags.Any())
            {
                <div class="post-taxonomy">
                    <strong>Tags</strong>
                    <div class="post-taxonomy__chips">
                        @foreach (var t in Model.PostTags.Select(pt => pt.Tag))
                        {
                            <a asp-controller="Blog"
                               asp-action="Tag"
                               asp-route-slug="@t.Slug"
                               class="badge bg-info text-dark">
                                @t.Name
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <div class="author-card">
        @if (adminProfile?.AvatarUrl != null)
        {
            <img src="@adminProfile.AvatarUrl" alt="@adminProfile.Name" class="author-card__avatar" />
        }
        else
        {
            <div class="author-card__avatar author-card__avatar--fallback">
                @(adminProfile?.Name?.Substring(0, 1) ?? "A")
            </div>
        }
        <div class="author-card__info">
            <h3 class="author-card__name">
                <a asp-controller="Home" asp-action="About">
                    @(adminProfile?.Name ?? Model.Author.UserName)
                </a>
            </h3>
            @if (!string.IsNullOrEmpty(adminProfile?.Bio))
            {
                <p class="author-card__bio">@adminProfile.Bio</p>
            }
            else
            {
                <p class="author-card__bio">Writer, developer, and tech enthusiast.</p>
            }
        </div>
    </div>

    <!-- Related Posts -->
    @if (relatedPosts.Any())
    {
        <div class="related-posts">
            <h3 class="related-posts__title">Related Posts</h3>
            <div class="related-posts__grid">
                @foreach (var relatedPost in relatedPosts)
                {
                    <article class="related-post">
                        @if (!string.IsNullOrEmpty(relatedPost.ImageUrl))
                        {
                            <a asp-controller="Blog" asp-action="Post" asp-route-slug="@relatedPost.Slug" class="related-post__image-link">
                                <img src="@relatedPost.ImageUrl" alt="@relatedPost.Title" class="related-post__image" />
                            </a>
                        }
                        <div class="related-post__content">
                            <h4 class="related-post__title">
                                <a asp-controller="Blog" asp-action="Post" asp-route-slug="@relatedPost.Slug">@relatedPost.Title</a>
                            </h4>
                            <p class="related-post__excerpt">@(relatedPost.Summary ?? "")</p>
                            <div class="related-post__meta">@relatedPost.PublishedAt?.ToString("MMM dd, yyyy")</div>
                        </div>
                    </article>
                }
            </div>
        </div>
    }

    <!-- Comments Section -->
    <div class="comments-section">
        <h3>Comments</h3>
        <div class="comments-card">
            <div class="comments-card__body">
                <!-- Utterances Comments - GitHub-based -->
                <script src="https://utteranc.es/client.js"
                        repo="pearlxcore/pearlxcore-dev"
                        issue-term="pathname"
                        label="comments"
                        theme="github-dark"
                        crossorigin="anonymous"
                        async>
                </script>
                <noscript>
                    <p class="text-muted">Please enable JavaScript to view the comments powered by <a href="https://utteranc.es" target="_blank">Utterances</a>.</p>
                </noscript>
            </div>
        </div>
        <p class="comments-note">
            💬 Comments are powered by <a href="https://utteranc.es" target="_blank">Utterances</a>, a lightweight comments widget built on GitHub issues. 
            To comment, you'll need a GitHub account.
        </p>
    </div>
</article>

@section Scripts {
    <script>
        // Generate Table of Contents
        const headings = document.querySelectorAll('.article-content h1, .article-content h2, .article-content h3');
        const tocList = document.getElementById('toc-list');
        if (tocList) {
            headings.forEach((heading, index) => {
                const id = 'heading-' + index;
                heading.id = id;
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = '#' + id;
                a.textContent = heading.textContent;
                li.appendChild(a);
                tocList.appendChild(li);
            });
        }
    </script>
}
